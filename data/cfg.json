{
  "app": {
    "id": "wpa360",
    "name": "WPA360",
    "default_tour_id": "coluna_1",
    "default_platform": "auto"
  },
  "features": {
    "minimap_widget": true,
    "vr": true,
    "editor": true,
    "service_worker": true
  },
  "ui": {
    "title": "WPA360 Virtual Tour",
    "hotspot_billboard": true,
    "minimap_card_position": "bottom-right",
    "chrome": {
      "show_brand_mark": false,
      "show_brand_name": false,
      "show_scene_select": true,
      "show_pwa_install_button": false,
      "show_platform_badge": false,
      "show_webxr_badge": false,
      "show_pwa_badge": false,
      "show_service_worker_badge": false,
      "show_input_badge": false,
      "show_standalone_badge": false
    }
  },
  "platform": {
    "allow_runtime_switch": true,
    "two_d": {
      "default_fov": 86,
      "min_fov": 55,
      "max_fov": 112,
      "mouse_sensitivity": 0.12,
      "touch_sensitivity": 0.18
    },
    "vr": {
      "enabled": true,
      "stereo_preview": true,
      "spatial_lock": true,
      "eye_yaw_offset": 3.2,
      "gaze_selection_degrees": 9,
      "hotspot_visibility_mode": "always"
    }
  },
  "asset_cache": {
    "preload_mode": "hybrid",
    "preload_current_scene": true,
    "preload_tour_scene_media": true,
    "preload_minimap_images": true,
    "hybrid_download_concurrency": 2,
    "hybrid_resident_scene_limit": 3
  }
}
